rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── nameIndex ──────────────────────────────────────
    // Public: anyone can look up a single name slug
    // No listing (prevents scraping the full guest list)
    match /nameIndex/{slug} {
      allow get:             if true;
      allow list:            if false;
      allow create, update,
            delete:          if false;
    }

    // ── invitees ───────────────────────────────────────
    match /invitees/{partyId} {

      // Anyone can fetch a specific invite doc (needed to display party name, maxGuests)
      allow get:  if true;

      // No listing the collection
      allow list: if false;

      // No creating or deleting from the client — managed via Admin SDK / console
      allow create, delete: if false;

      // Allow RSVP updates until the deadline
      allow update: if
        // ① Deadline: change this to your actual RSVP close date
        request.time < timestamp.date(2027, 3, 20) &&

        // ② Only these two fields may change
        request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['rsvp', 'rsvpUpdatedAt']) &&

        // ③ rsvp must be a map with required shape
        request.resource.data.rsvp is map &&
        request.resource.data.rsvp.attending is bool &&
        request.resource.data.rsvp.guestCount is int &&

        // ④ Guest count must be non-negative and within the allowed maximum
        request.resource.data.rsvp.guestCount >= 0 &&
        request.resource.data.rsvp.guestCount <= resource.data.maxGuests &&

        // ⑤ If declining, guest count must be 0
        (
          request.resource.data.rsvp.attending == true ||
          request.resource.data.rsvp.guestCount == 0
        ) &&

        // ⑥ Timestamp must be the server time (prevents client spoofing)
        request.resource.data.rsvpUpdatedAt == request.time;
    }
  }
}
